{
  "manifest_version": 3,
  "name": "Magic Numbers",
  "version": "1.0",
  "description": "Shows estimated total trip cost next to per-night Walt Disney World resort prices, and nightly pricing next to package prices",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://disneyworld.disney.go.com/resorts/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "world": "MAIN"
    }
  ]
}
